{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Represents an entry on the game leaderboard.",
      "type": "object",
      "properties": {
        "name": { 
          "type": "string",
          "description": "The name of the player."
        },
        "time": { 
          "type": "number",
          "description": "The time elapsed in milliseconds."
        },
        "date": { 
          "type": "number",
          "description": "Timestamp when score was achieved."
        }
      },
      "required": ["name", "time", "date"]
    }
  },
  "firestore": {
    "/artifacts/{appId}/public/data/leaderboard/{leaderboardId}": {
      "schema": "LeaderboardEntry",
      "description": "The public leaderboard scores for matches."
    }
  }
}
